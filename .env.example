# Omniventory — environment variable template
# Copy this file to .env and fill in the values.
# The real .env is git-ignored; only .env.example is committed.

# Published image tag to run (production compose pulls
# ghcr.io/omniventory/omniventory:<IMAGE_TAG>). Defaults to `latest`; pin a
# specific release for reproducible deploys, e.g. IMAGE_TAG=0.1.0
IMAGE_TAG=latest

# Secret key for session signing.
# Leave blank to auto-generate and persist on first run (stored in the
# app_config table inside the SQLite DB).  Set explicitly if you need a
# stable key across container rebuilds when the DB is ephemeral, or to
# rotate the key (all existing sessions are invalidated on change).
SECRET_KEY=

# Runtime environment: development | production
ENVIRONMENT=production

# SQLite database path (inside the container)
DATABASE_URL=sqlite:////app/data/omniventory.db

# Host port mapped to the container's port 8000 (default: 8000)
APP_PORT=8000

# Host directory for the SQLite bind mount (default: ./data).
# The container runs as uid/gid 1000:1000; this directory (and the SQLite
# file inside it) will be owned by that uid — matching the normal host user
# makes backups and direct file access straightforward.
DATA_DIR=./data
